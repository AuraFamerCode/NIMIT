# Environment Variables for AlgoBacktest
# Copy to .env and fill in your values.
# NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────
# Get a free API key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# ── Database ──────────────────────────────────────────────
DATABASE_URL=file:./backtest.db
# For PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@db:5432/backtest"

# ── LLM Model ─────────────────────────────────────────────
# See available models at https://openrouter.ai/models
MODEL=moonshotai/kimi-k2.6

# ── Branding (for OpenRouter billing headers) ─────────────
YOUR_SITE_URL=http://localhost:3000
YOUR_SITE_NAME=AI Backtester

# ── Auth ──────────────────────────────────────────────────
# Replace with a secure random key (openssl rand -hex 32)
SECRET_KEY=change-me-in-production

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
NODE_ENV=development